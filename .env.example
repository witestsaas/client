# ==============================
# Client Frontend — .env.example
# ==============================
# Copy this file to .env and fill in the values.
# All VITE_ vars are embedded at build time.
# ==============================

# ==============================
# API
# ==============================
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_SAAS_PLATFORM_URL=http://localhost:3000

# ==============================
# Socket.IO (optional — defaults to window.location)
# ==============================
VITE_NEXT_PUBLIC_SOCKET_URL=

# ==============================
# AI Chat (optional — n8n webhook integration)
# ==============================
VITE_N8N_CHAT_WEBHOOK_URL=
